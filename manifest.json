{
  "manifest_version": 3,
  "name": "edge-font",
  "version": "0.2.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "edge-font",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
